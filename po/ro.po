msgstr "Nu s-a putut crea conexiunea TLS:"

#: tls/gnutls/gtlsconnection-gnutls.c:244
#: tls/openssl/gtlsclientconnection-openssl.c:503
#: tls/openssl/gtlsserverconnection-openssl.c:418
#, c-format
